### ─── Variables ────────────────────────────────────────────────────────────────
@userService  = http://localhost:8080
@tradingService = http://localhost:8082

# Supervisor: Admin — EmployeeID 3 (seeded as admin@raf.rs, 3rd employee)
# Agent: Marko Markovic — EmployeeID 4 (seeded as marko@raf.rs, 4th employee, limit=100000)
@supervisorId = 3
@agentId = 4

# Agent's account number — look up in banking service:
#   SELECT account_number FROM accounts WHERE identity_id =
#     (SELECT identity_id FROM identities WHERE email = 'marko@raf.rs')
@agentAccountNumber = 444000100000000004

# Set from DB after portfolio assets appear:
#   SELECT asset_ownership_id FROM asset_ownerships
#   WHERE user_id = 4 AND owner_type = 'actuary';
@ownershipId = 1

# Set from DB — the asset_id of an option owned by the actuary:
#   SELECT asset_id FROM asset_ownerships
#   WHERE user_id = 4 AND owner_type = 'actuary'
#   AND asset_id IN (SELECT asset_id FROM options);
@optionAssetId = 1


### ─── Step 1a: Login as supervisor (Admin) ─────────────────────────────────────
# @name loginSupervisor
POST {{userService}}/api/auth/login HTTP/1.1
Content-Type: application/json

{
  "email": "admin@raf.rs",
  "password": "admin123"
}


###
@supervisorToken = {{loginSupervisor.response.body.$.token}}


### ─── Step 1b: Login as agent (Marko) ──────────────────────────────────────────
# @name loginAgent
POST {{userService}}/api/auth/login HTTP/1.1
Content-Type: application/json

{
  "email": "marko@raf.rs",
  "password": "pass123"
}


###
@agentToken = {{loginAgent.response.body.$.token}}


### ─── Step 2: Get actuary (supervisor) portfolio ───────────────────────────────
# Returns all assets owned by the actuary.
# actId = EmployeeID from JWT (not IdentityID).
GET {{tradingService}}/api/actuary/{{supervisorId}}/assets HTTP/1.1
Authorization: Bearer {{supervisorToken}}


### ─── Step 3: Get actuary (agent) portfolio ───────────────────────────────────
# Agent fetching their own portfolio. Any employee with trading permission can access.
GET {{tradingService}}/api/actuary/{{agentId}}/assets HTTP/1.1
Authorization: Bearer {{agentToken}}


### ─── Step 4: Get actuary portfolio profit ────────────────────────────────────
# Returns total profit in RSD across all owned assets for the actuary.
GET {{tradingService}}/api/actuary/{{agentId}}/assets/profit HTTP/1.1
Authorization: Bearer {{agentToken}}


### ─── Step 5: Get actuary accumulated tax ──────────────────────────────────────
# Returns total capital gains tax owed by the actuary (unpaid, in RSD).
GET {{tradingService}}/api/actuary/{{agentId}}/accumulated-tax HTTP/1.1
Authorization: Bearer {{agentToken}}


### ─── Step 6: Publish actuary assets to OTC ───────────────────────────────────
# Makes N of the actuary's shares publicly visible on the OTC portal.
# ownershipId from DB query above. amount is additive.
PATCH {{tradingService}}/api/actuary/{{agentId}}/assets/{{ownershipId}}/publish HTTP/1.1
Authorization: Bearer {{agentToken}}
Content-Type: application/json

{
  "amount": 2
}


### ─── Step 7: Verify OTC listing (supervisor token) ───────────────────────────
# Actuary-published assets should appear alongside client-published ones.
GET {{tradingService}}/api/otc/public?page=1&page_size=10 HTTP/1.1
Authorization: Bearer {{supervisorToken}}


### ─── Step 8: Exercise a call option (supervisor only) ────────────────────────
# Exercises one contract of an in-the-money call option owned by the actuary.
# Conditions: option must be CALL, stock price > strike price, actuary must own it.
# The resulting stock shares are credited to the actuary's portfolio.
# optionAssetId = asset_id of the option (NOT the listing_id).
POST {{tradingService}}/api/actuary/{{supervisorId}}/options/{{optionAssetId}}/exercise HTTP/1.1
Authorization: Bearer {{supervisorToken}}
Content-Type: application/json

{
  "account_number": "{{agentAccountNumber}}"
}


### ─── Step 9: List orders for an actuary (agent) ───────────────────────────────
# Returns paginated orders placed by a specific actuary (filtered to ACTUARY owner type).
# Any employee with trading permission can view any actuary's orders.
# Permissions: Trading permission + IdentityEmployee (same as all other /actuary routes).
GET {{tradingService}}/api/actuary/{{agentId}}/orders HTTP/1.1
Authorization: Bearer {{agentToken}}


### ─── Step 10: Supervisor lists another actuary's orders ───────────────────────
GET {{tradingService}}/api/actuary/{{agentId}}/orders?status=PENDING&is_done=false&page=1&page_size=20 HTTP/1.1
Authorization: Bearer {{supervisorToken}}


### ─── Bonus: Supervisor views all actuary portfolios ───────────────────────────
# Supervisors can view any actuary's portfolio (no self-restriction).
GET {{tradingService}}/api/actuary/{{agentId}}/assets HTTP/1.1
Authorization: Bearer {{supervisorToken}}


### ─── Bonus: Supervisor portfolio and profit ───────────────────────────────────
GET {{tradingService}}/api/actuary/{{supervisorId}}/assets/profit HTTP/1.1
Authorization: Bearer {{supervisorToken}}
