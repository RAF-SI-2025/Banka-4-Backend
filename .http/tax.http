### ─── Variables ────────────────────────────────────────────────────────────────
@userService  = http://localhost:8080
@tradingService = http://localhost:8082

# Client: Ana Anic — ClientID 3
@clientId = 3

# Actuary: Marko (agent) — EmployeeID 4
@agentId = 4


### ─── Step 1: Login as supervisor (Admin) ──────────────────────────────────────
# @name loginSupervisor
POST {{userService}}/api/auth/login HTTP/1.1
Content-Type: application/json

{
  "email": "admin@raf.rs",
  "password": "admin123"
}


###
@supervisorToken = {{loginSupervisor.response.body.$.token}}


### ─── Step 2: Login as client (Ana Anic) ───────────────────────────────────────
# @name loginClient
POST {{userService}}/api/auth/login HTTP/1.1
Content-Type: application/json

{
  "email": "ana.anic@example.com",
  "password": "password123"
}


###
@clientToken = {{loginClient.response.body.$.token}}


### ─── Step 3: List all users with tax info (supervisor only) ───────────────────
# Returns clients and actuaries with total tax owed in RSD.
# Filterable by userType (client | actuary), first_name, last_name.
GET {{tradingService}}/api/tax?page=1&page_size=10 HTTP/1.1
Authorization: Bearer {{supervisorToken}}


### ─── Step 3a: Filter by user type = client ────────────────────────────────────
GET {{tradingService}}/api/tax?page=1&page_size=10&userType=client HTTP/1.1
Authorization: Bearer {{supervisorToken}}


### ─── Step 3b: Filter by user type = actuary ───────────────────────────────────
GET {{tradingService}}/api/tax?page=1&page_size=10&userType=actuary HTTP/1.1
Authorization: Bearer {{supervisorToken}}


### ─── Step 3c: Filter by name ──────────────────────────────────────────────────
GET {{tradingService}}/api/tax?page=1&page_size=10&first_name=Ana HTTP/1.1
Authorization: Bearer {{supervisorToken}}


### ─── Step 4: Get client accumulated tax ───────────────────────────────────────
# Client can view their own tax. Supervisor can view anyone's.
GET {{tradingService}}/api/client/{{clientId}}/accumulated-tax HTTP/1.1
Authorization: Bearer {{clientToken}}


### ─── Step 5: Get actuary accumulated tax ──────────────────────────────────────
# Requires employee (actuary) auth with trading permission.
# @name loginAgent
POST {{userService}}/api/auth/login HTTP/1.1
Content-Type: application/json

{
  "email": "marko@raf.rs",
  "password": "pass123"
}

###
@agentToken = {{loginAgent.response.body.$.token}}

GET {{tradingService}}/api/actuary/{{agentId}}/accumulated-tax HTTP/1.1
Authorization: Bearer {{agentToken}}


### ─── Step 6: Trigger tax collection (supervisor only) ─────────────────────────
# Runs the monthly tax collection process for all users immediately.
# Collects 15% capital gains tax and pays it to the State's RSD account.
# WARNING: This is normally a scheduled job — use with caution in production.
POST {{tradingService}}/api/tax/collect HTTP/1.1
Authorization: Bearer {{supervisorToken}}


### ─── Step 7: Verify tax was collected ─────────────────────────────────────────
# After collection, accumulated tax should be reduced (or zero).
GET {{tradingService}}/api/client/{{clientId}}/accumulated-tax HTTP/1.1
Authorization: Bearer {{clientToken}}
