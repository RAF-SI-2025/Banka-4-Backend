### ─── Variables ────────────────────────────────────────────────────────────────
@userService  = http://localhost:8080
@tradingService = http://localhost:8082

# Client: Ana Anic — ClientID 3, has RSD account with 100,000 RSD
# Ana has `trading` and `trading.margin` permissions seeded.
@clientId = 3
@accountNumber = 444000112345678913

# Set from the "asset_ownership_id" field after querying the DB:
#   SELECT asset_ownership_id FROM asset_ownerships
#   WHERE user_id = (SELECT client_id FROM clients
#                   JOIN identities ON clients.identity_id = identities.id
#                   WHERE identities.email = 'ana.anic@example.com')
#   AND owner_type = 'client';
@ownershipId = 1


### ─── Step 1: Login as client (Ana Anic) ───────────────────────────────────────
# @name loginClient
POST {{userService}}/api/auth/login HTTP/1.1
Content-Type: application/json

{
  "email": "ana.anic@example.com",
  "password": "password123"
}


###
@clientToken = {{loginClient.response.body.$.token}}


### ─── Step 2: Get client portfolio ─────────────────────────────────────────────
# Returns all assets owned by the client.
# Wait for any previously placed orders to fill before calling this.
GET {{tradingService}}/api/client/{{clientId}}/assets HTTP/1.1
Authorization: Bearer {{clientToken}}


### ─── Step 3: Get client portfolio profit ──────────────────────────────────────
# Returns total profit in RSD across all owned assets.
GET {{tradingService}}/api/client/{{clientId}}/assets/profit HTTP/1.1
Authorization: Bearer {{clientToken}}


### ─── Step 4: Get client accumulated tax ───────────────────────────────────────
# Returns total capital gains tax owed by the client (unpaid, in RSD).
GET {{tradingService}}/api/client/{{clientId}}/accumulated-tax HTTP/1.1
Authorization: Bearer {{clientToken}}


### ─── Step 5: Publish assets to OTC ───────────────────────────────────────────
# Makes N shares publicly visible on the OTC portal.
# amount replaces the current public amount (additive — new total = old + amount).
# Use 0 to effectively unpublish (set public_amount back to 0 if old was 0).
# Must have owned assets first (ownershipId from DB query above).
PATCH {{tradingService}}/api/client/{{clientId}}/assets/{{ownershipId}}/publish HTTP/1.1
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "amount": 2
}


### ─── Step 6: Verify OTC listing ───────────────────────────────────────────────
# Published assets should appear here with available_amount = public_amount - reserved.
GET {{tradingService}}/api/otc/public?page=1&page_size=10 HTTP/1.1
Authorization: Bearer {{clientToken}}


### ─── Step 7: Get client investment fund positions ─────────────────────────────
# Returns all investment fund positions for the client.
# Each entry shows:
#   fund_id, fund_name, fund_description
#   clients_share_percent   — client's share of the fund (total invested by client / total invested in fund × 100)
#   clients_share_value_rsd — current market value of the client's share in RSD
#   total_profit            — clients_share_value_rsd minus what the client invested
#
# Pre-requisite: client must have invested in at least one fund.
# Seed funds and invest via /api/investment-funds (see fund_orders.http).
#
# DB query to verify:
#   SELECT cfp.*, f.name AS fund_name
#   FROM client_fund_positions cfp
#   JOIN investment_funds f ON f.fund_id = cfp.fund_id
#   WHERE cfp.client_id = 3 AND cfp.owner_type = 'CLIENT';
GET {{tradingService}}/api/client/{{clientId}}/funds HTTP/1.1
Authorization: Bearer {{clientToken}}

